# Optional: enable OpenList storage instead of local outputs/.
# When OPENLIST_BASE_URL is set, rendered GIFs are uploaded to OpenList
# and OPENLIST_VIDEO_PATH is treated as the remote directory path.
OPENLIST_BASE_URL=https://your-openlist.example.com
OPENLIST_USERNAME=your-openlist-username
OPENLIST_PASSWORD=your-openlist-password
OPENLIST_VIDEO_PATH=/video-to-gif
